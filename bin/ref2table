#!/usr/bin/env node
/**
 * Ref2Link command-line tool
 * 
 * Usage: 
 *     /> node ref2table --inputtext='T-36/04' --format=json --linkeddata=true
 */
import fs from 'fs';
import path from 'path';
import { performance } from 'perf_hooks';
import { setArgs } from './lib/index.js';
import yargsPkg from 'yargs';
import { fileURLToPath } from 'url';
import { JSDOM } from "jsdom";
import XMLHttpRequestPkg from 'xmlhttprequest';
import $ from 'jquery';

const argv = yargsPkg.argv;
const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

const XMLHttpRequest = XMLHttpRequestPkg.XMLHttpRequest;

/**
 * Disable logging
 */
console.log = console.info = console.debug = console.warn = function () { };

/** 
 * We setup a virtual DOM using the JSDOM library. This way the Ref2Link library will work exactly as it would in a browser, with all functionality preserved. 
 * We also expose the JQuery global variable `$`. 
 * 
 * Same approach is used with the Webservice integration. 
 */

/** 
 * JQuery requires a window.document 
 */
const html = '<html><body></body></html>';
const dom = new JSDOM(html);

global.window = dom.window;
global.document = dom.window.document;
global.performance = performance;
let jQuery = $(dom.window);

global.jQuery = global.$ = jQuery;

global.$.support.cors = true; // cross domain, Cross-origin resource sharing
global.$.ajaxSettings.xhr = function () {
    return new XMLHttpRequest();
};

const constantsInput = fs.readFileSync(path.resolve(__dirname, "../data/rules.json"), 'utf8');
const constants = JSON.parse(constantsInput);
global["R2L_CONSTANTS"] = constants;

/**
 * Arguments:
    --inputtext       Text to process                                     
    --input           Path to input file                                   
    --inputdir        Path to input dir - Will process all files inside  
    --output          Path to output file                                 
    --outputdir       Path to output dir - Used with `inputdir`
    --langsource      Use language specific rules [ISO2] (default=MULTI)
    --langtarget      Provide tailored target urls [ISO2]
    --format          Ref2Table output format [json/xml] (default=json)       
    --environment     Comma-separated environments to use (default=*)
    --ruletype        Comma-separated rules to use
    --target          Comma-separated targets to use
    --excludetarget   Comma-separated targets to be excluded
    --linkeddata      Enable Linked data (default=false)
    --linkeddatamode  Linked data settings (default=all) 
                      Example: check-exist,seq-number,metadata,all    
    --htmlmode        Parse input as HTML (default=false)
    --strictrules     Comma-separated rules to mark as strict. Only available for `eurlex.act`. Example usage: strictrules=eurlex.act
    --pointintime     Use ELI Point in time. Format: YYYY-MM-DD. defaults to `/oj`

 */

function getInput() {
    if (argv.inputtext) {
        return argv.inputtext;
    }
    if (argv.input) {
        try {
            return fs.readFileSync(argv.input, 'utf8');
        }
        catch (e) {
            return null;
        }
    }
    return null;
}


import('../ref2link.js').then(_ => {
    let inputText = getInput();
    let inputFormat = String(argv.format).toLowerCase() === "xml" ? "xml" : "json";
    let options = {};

    if (!inputText) {
        console.error("Failed to read input text");
        process.exit(1);
    }

    /**
     * Apply filters
     */
    setArgs(argv, R2L);

    R2L.parse(inputText, inputFormat, options).then((data) => {

        let result = null;
        if (!data) {
            console.error("Failed to parse content");
            process.exit(1);
        }
        else {
            result = (inputFormat === "json") ? JSON.stringify(data.result, null, 2) : data.result;
        }

        /**
         * Send response
         */
        if (argv.output) {
            try {
                fs.writeFileSync(path.normalize(argv.output), result);
            }
            catch (e) {
                console.error("Failed to write to file", argv.output);
                process.exit(1);
            }
        }
        else {
            process.stdout.write(result);
        }
    }, (error) => {
        console.error(error);
    });
});